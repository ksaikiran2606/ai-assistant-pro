# Application
APP_NAME=AI Assistant Pro
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database — Aiven example (encode special chars in password: @ → %40)
DATABASE_URL=mysql+pymysql://avnadmin:YOUR_PASSWORD@YOUR_HOST.aivencloud.com:PORT/defaultdb
MYSQL_SSL_CA=

# AI Provider: groq | openai | gemini
# Groq is recommended for free testing — https://console.groq.com/keys
AI_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile

OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4o-mini

# Gemini key from https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate Limiting
RATE_LIMIT=60/minute
